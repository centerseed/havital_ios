"training_plan.loading_schedule" = "スケジュールを読み込み中...";

// MARK: - Training Type Info
"training_type_info.how_to_run_title" = "走り方";
"training_type_info.why_run_title" = "なぜ走るのか";
"training_type_info.logic_title" = "トレーニングロジック";
"training_type_info.role_title" = "週間スケジュールでの役割";

// Recovery Run
"training_type_info.recovery_run.title" = "リカバリーラン";
"training_type_info.recovery_run.how_to_run" = "最もリラックスしたランニング方法。ゆっくりでも大丈夫—「良いデータ」より「体の快適さ」に焦点を当てましょう。";
"training_type_info.recovery_run.why_run" = "リカバリーランはアクティブリカバリーの一部です。速すぎると修復を妨げ、遅すぎると効果がない—重要なのは「酸素を含んだ血液を疲れた筋肉に流すこと」です。";
"training_type_info.recovery_run.logic" = "非常に低強度の有酸素トレーニング（<65% HRmax）、乳酸の除去を助け、代謝と神経系の回復を促進します。静的休息と比較して、次のセッションの準備が早くなります。";
"training_type_info.recovery_run.role" = "通常、高強度ワークアウトやロングランの翌日にスケジュールされ、トレーニング結果を「吸収」するための鍵となります。";

// Tempo Run
"training_type_info.tempo.title" = "テンポラン";
"training_type_info.tempo.how_to_run" = "安定した、やや困難だが持続可能なペース。「きつい、でも崩れない」と感じるべきです。";
"training_type_info.tempo.why_run" = "テンポランはレースペースに慣れさせます。中高強度での呼吸とペースのコントロールを鍛え、持久力とスピードをつなぐ橋となります。";
"training_type_info.tempo.logic" = "乳酸閾値付近（最大心拍数の約80–88%）、体の乳酸処理能力を改善し、「崩れずに高速度を維持する」パフォーマンスを向上させます。";
"training_type_info.tempo.role" = "通常週の半ば、レースペースのシミュレーションとして、週末のロングランや週初めのイージーランと組み合わせて安定したリズムの週を形成します。";

// Threshold Run
"training_type_info.threshold.title" = "閾値ラン";
"training_type_info.threshold.how_to_run" = "テンポランよりわずかにきついが、まだ持続可能。「挑戦的だがやり遂げられる」と感じ、心拍数は高いが制御されています。";
"training_type_info.threshold.why_run" = "閾値ランは持久力の壁を破る鍵です。より長く高速度を維持できるようにし、マラソンパフォーマンスの向上に重要です。";
"training_type_info.threshold.logic" = "乳酸閾値強度（最大心拍数の約85–90%）をターゲットとし、体が乳酸蓄積を遅らせ、疲労耐性を向上させます。長期的な実践により、持続スピードとレースパフォーマンスが大幅に向上します。";
"training_type_info.threshold.role" = "通常、ピークトレーニング期間の週の半ばにスケジュールされ、イージーランでウォームアップし、リカバリーランで刺激を吸収します。";

// Interval Run
"training_type_info.interval.title" = "インターバルラン";
"training_type_info.interval.how_to_run" = "短時間の全力スプリントと回復の交互、息切れし疲れますが、「すべてのセットを完了」する必要があります。";
"training_type_info.interval.why_run" = "これはスピードと心肺パワーを向上させる鍵となるワークアウトです。高強度の刺激が体に「より速く走り、より速く回復する」ことを教えます。";
"training_type_info.interval.logic" = "高強度インターバルトレーニング（HIIT）、VO₂maxと神経筋反応を刺激します。心拍出量、酸素供給、筋肉の酸化能力を向上させます。";
"training_type_info.interval.role" = "通常週の半ば、週の「強度のスター」。イージーランや休息日と組み合わせて十分な回復時間を確保します。";

// LSD (Long Slow Distance)
"training_type_info.lsd.title" = "LSD（ロングスローディスタンス）";
"training_type_info.lsd.how_to_run" = "ペースを落として時間を延ばします。永遠に走れるように感じるべきで、安定しているがきつくありません。";
"training_type_info.lsd.why_run" = "長時間のランニングは精神的および肉体的持久力を鍛え、体が長時間脂肪を燃料として使用することを学びます—マラソントレーニングの古典的なコアワークアウト。";
"training_type_info.lsd.logic" = "長時間低強度有酸素トレーニング、心肺機能、筋肉持久力、エネルギー利用効率を強化します。毛細血管の成長を促進し、筋肉の酸素使用を改善します。";
"training_type_info.lsd.role" = "通常週末、週の「持久力の柱」。週の半ばのテンポランやインターバルランと組み合わせて完全な有酸素能力を構築します。";

// Long Run
"training_type_info.long_run.title" = "ロングラン";
"training_type_info.long_run.how_to_run" = "イージーペースよりわずかに速く走りますが、全体を通して持続可能。レースペースをシミュレートしているように感じ、リズミカルな呼吸、前に集中。";
"training_type_info.long_run.why_run" = "ロングランは持久力をテストし構築します。時間が延長されても安定した出力を維持することを習慣づけ、疲労の中でも体を機能させ続けることを訓練します。";
"training_type_info.long_run.logic" = "中等強度の長時間有酸素トレーニング（最大心拍数の約70–80%）。この強度では、体は脂肪とグリコーゲンの両方を燃料として使用し、エネルギー利用効率と筋肉持久力を向上させます。また、「レースペースの安定性」と「精神的耐性」を強化する重要なワークアウト。";
"training_type_info.long_run.role" = "通常週末、週で最も長いセッション。強化期やレース準備期間中、レース条件をシミュレートするコアトレーニングで、イージーランやリカバリーランと組み合わせて負荷を吸収します。";

"training_type_info.easy.title" = "イージーラン Easy Run";
"training_type_info.easy.how_to_run" = "非常にリラックスしたペース。楽に会話でき、ほぼ息が上がらない。「走る喜びのために」走っている感覚です。";
"training_type_info.easy.why_run" = "イージーランは日々のトレーニングの基礎です。過度な疲労を起こさずに規則正しい走行に体を慣らし、ランニングへの情熱を続ける鍵となります。";
"training_type_info.easy.logic" = "低強度有酸素トレーニング（最大心拍数の約60–70%）。この強度では、体は脂肪を主な燃料源として安定して利用しながら、有酸素能力と毛細血管の成長を構築します。";
"training_type_info.easy.role" = "訓練週の「日常の主役」。ハードセッション前後にイージーランでウォームアップと回復をしたり、単独でイージーデーとして使用して、プレッシャーなしにトレーニング負荷に体を適応させます。";

"training_type_info.combination.title" = "コンビネーショントレーニング Combination Training";
"training_type_info.combination.how_to_run" = "1つのセッション内に複数の強度ゾーンを組み合わせます。楽に開始し、徐々にペースを上げるか、スプリントと回復を交互に行います。";
"training_type_info.combination.why_run" = "コンビネーショントレーニングは1つのセッション内で複数の能力に刺激を与えます。変動する強度下で素早く適応し、心肺と筋肉の総合的なパフォーマンスを向上させるよう訓練します。";
"training_type_info.combination.logic" = "有酸素トレーニングと無酸素トレーニングの利点を統合し、強度の変動を通じて複数の生理系を刺激します。単一強度セッションと比較して、持久力、速度、適応能力をより包括的に構築します。";
"training_type_info.combination.role" = "時間が限られているが包括的なトレーニング効果を望む場合、週中のメインセッションとして機能します。実際のレースの変動するペースをシミュレートするため、レース準備期間中にも一般的です。";

"training_type_info.rest.title" = "レストデー Rest Day";
"training_type_info.rest.how_to_run" = "構造化されたランニングトレーニングはありません。軽いウォーキングまたは完全な静的休息を選択でき、体の声に耳を傾けてください。";
"training_type_info.rest.why_run" = "休息はトレーニング計画の中で最も見落とされやすいのに、最も重要な部分です。完全な休息日は筋肉修復、神経系の回復、エネルギー貯蔵の補充を可能にします。";
"training_type_info.rest.logic" = "トレーニング負荷がない場合、体は深い修復を行います。筋肉タンパク質合成が増加し、疲労毒素が消失し、ホルモンと免疫系のバランスが再調整される——これが「休息を通じて強くなる」プロセスです。";
"training_type_info.rest.role" = "毎週1～2日の完全休息日をスケジュールします。通常、ハードトレーニング後に配置します。十分な休息日は過度なトレーニングを防ぎ、長期的なパフォーマンスと健康を維持します。";

// MARK: - 新しいインターバルトレーニングタイプ情報
"training_type_info.strides.title" = "ストライド";
"training_type_info.strides.how_to_run" = "短距離（約80-100メートル）の加速走。イージーペースから始め、徐々にスプリント近くまで加速し、減速して止まります。リラックスして、良いフォームに集中。";
"training_type_info.strides.why_run" = "ストライドはランニングエコノミーと神経筋協調性を向上させます。脚がより速い回転に慣れ、レース前のウォームアップにも最適。";
"training_type_info.strides.logic" = "神経筋トレーニングで、短時間の高速度刺激により筋繊維の動員効率と脚の協調性を改善。距離が短く完全回復するため、著しい疲労は生じません。";
"training_type_info.strides.role" = "通常、イージーラン後または高強度トレーニング前のウォームアップとして。週2-3回、各4-8本実施。";

"training_type_info.hill_repeats.title" = "坂道リピート";
"training_type_info.hill_repeats.how_to_run" = "5-10%の勾配の坂道を見つけ、安定したがチャレンジングなペースで駆け上がり、ジョグまたは歩いて下坂で回復。脚の推進力と体の前傾に集中。";
"training_type_info.hill_repeats.why_run" = "坂道ランは「偽装されたウェイトトレーニング」。脚の筋力を強化し、フォームを改善し、平地スプリントより怪我のリスクを低減。";
"training_type_info.hill_repeats.logic" = "上り坂はより大きな筋力出力が必要で、大臀筋、大腿四頭筋、ふくらはぎを効果的にトレーニング。平地スプリントより関節への衝撃は少なく、筋肉負荷は大きい。";
"training_type_info.hill_repeats.role" = "通常、ベース期または筋力発達期に週1回配置。有酸素基礎と高強度インターバルをつなぐ重要な移行トレーニング。";

"training_type_info.cruise_intervals.title" = "クルーズインターバル";
"training_type_info.cruise_intervals.how_to_run" = "閾値ペース（20-30分維持できる最速ペース）でインターバルを行い、各組間に短い回復（1-2分のジョグ）。";
"training_type_info.cruise_intervals.why_run" = "クルーズインターバルは閾値強度でより多くのボリュームを蓄積できます。短い回復により、この重要な強度ゾーンでより長い時間を過ごせます。";
"training_type_info.cruise_intervals.logic" = "閾値トレーニングの変形で、乳酸閾値付近に長時間体を置きます。インターバル構造により、良いフォームを維持しながらより高い総ボリュームが可能。";
"training_type_info.cruise_intervals.role" = "通常、レース準備期に閾値走の上級版として使用。ハーフマラソン・フルマラソンのパフォーマンス向上に重要。";

// MARK: - 新しいコンビネーショントレーニングタイプ情報
"training_type_info.fartlek.title" = "ファルトレク";
"training_type_info.fartlek.how_to_run" = "「ファルトレク」はスウェーデン語で「速度遊び」。走りながら自由にペースを変える—次の街灯までスプリント、公園の入口でスローダウン。固定構造なし、感覚で走る。";
"training_type_info.fartlek.why_run" = "ファルトレクはトレーニングを楽しくしながら、ペース変化への適応を訓練。単調さを打破し、レース時のペース変動をシミュレート。";
"training_type_info.fartlek.logic" = "非構造化の混合強度トレーニングで、有酸素・無酸素システムの両方を刺激。自由な形式は精神的疲労を減らし、楽しみながらトレーニング効果を得られます。";
"training_type_info.fartlek.role" = "構造化インターバルの代替、または回復週の軽い変速走として。どのトレーニング段階にも適合、特に気分転換が必要な時に。";

"training_type_info.fast_finish.title" = "ファストフィニッシュ走";
"training_type_info.fast_finish.how_to_run" = "最初の70%はイージーペース、最後の30%でテンポペースまたはそれ以上に加速。終了時にはチャレンジを感じながらも完走できるべき。";
"training_type_info.fast_finish.why_run" = "ファストフィニッシュランは疲労時にペースを維持・加速する訓練—まさにレース後半の挑戦。「疲れても加速する」感覚を体に覚えさせます。";
"training_type_info.fast_finish.logic" = "グリコーゲン枯渇、筋肉疲労状態での高強度走により、脂肪代謝能力と疲労耐性を向上。フォームと集中力の維持も訓練。";
"training_type_info.fast_finish.role" = "通常、レース準備期の週末ロングランで実施。レース後半をシミュレートする重要なトレーニングで、自信構築に有効。";

// MARK: - 新しいレースペーストレーニング情報
"training_type_info.race_pace.title" = "レースペース走";
"training_type_info.race_pace.how_to_run" = "目標レースペースで走る。安定したリズムの維持に集中し、このスピードでの呼吸、ケイデンス、体の感覚に慣れる。";
"training_type_info.race_pace.why_run" = "レースペース走は体と脳に目標速度を記憶させます。レース当日、時計を見なくても自然にこのペースで走れるようになります。";
"training_type_info.race_pace.logic" = "目標ペースを繰り返し練習することで、神経筋記憶とペース知覚能力を構築。現在のフィットネスで目標達成可能かの評価にも役立ちます。";
"training_type_info.race_pace.role" = "通常、レース4-8週前から配置し、距離は徐々に増加。最も重要なレース特化トレーニングの一つ。";

// MARK: - 新しいVO2max向上トレーニング情報
"training_type_info.norwegian_4x4.title" = "ノルウェー4×4";
"training_type_info.norwegian_4x4.how_to_run" = "4分間の高強度走を4セット行い（92% 最大心拍数）、各セット間に3分間のイージーラン回復を挟む。VO₂max ペースを安定して維持します。「非常に大変だけれど全セット完走できる」という感覚が目安です。";
"training_type_info.norwegian_4x4.why_run" = "ノルウェー4×4はVO₂maxを向上させる最も効率的なトレーニング方法です。科学的研究では、このプロトコルが短期間で有酸素能力を約7%向上させることが示されており、レース前の重要なワークアウトです。";
"training_type_info.norwegian_4x4.logic" = "VO₂max強度（92% 最大心拍数、95-100% VO₂max）で実施し、有酸素系と無酸素系の両方を最高レベルまで刺激します。4分間は心肺に十分な負荷をかけるのに長く、3分間の回復により全セット完了できます。この設計により最大強度でのトレーニング量が大きく蓄積されます。";
"training_type_info.norwegian_4x4.role" = "通常、ビルドアップ期またはレース準備期に使用し、最大週1回に制限。イージーランと組み合わせ、十分な回復を確保してください。連続した週の実施には不向きで、回復週とのバランスが必要です。";

"training_type_info.short_interval.title" = "短間隔走";
"training_type_info.short_interval.how_to_run" = "短距離（400-600m）の高強度走を6-10本実施し、各本間に1-2分のイージーラン回復を挟む。全力でスプリントし、呼吸をしっかり上げます。";
"training_type_info.short_interval.why_run" = "短間隔走はスピードと爆発力を鍛えます。短距離により全力を維持でき、十分な回復時間によって全本完走を支援。特に5Kレース準備に有効です。";
"training_type_info.short_interval.logic" = "高強度間隔トレーニング(HIIT)の一種で、VO₂maxと神経筋反応を刺激します。短距離は最高速度と走行ケイデンス向上に特に効果的であり、加速能力も鍛えられます。";
"training_type_info.short_interval.role" = "通常、基礎スピード開発期または5K準備期に使用。最大週1回、イージーランと休息日と組み合わせます。連続実施は受傷リスク増加につながります。";

"training_type_info.long_interval.title" = "長間隔走";
"training_type_info.long_interval.how_to_run" = "より長い距離（1200-2000m）の高強度走を4-6本実施し、各本間に2-3分のイージーラン回復を挟む。短間隔走より若干遅いペースですが、高強度を維持します。";
"training_type_info.long_interval.why_run" = "長間隔走は短間隔走と持続走の橋渡し。VO₂maxを刺激しながら長時間高ペース維持でき、ハーフマラソンと10Kレース準備に特に適しています。";
"training_type_info.long_interval.logic" = "短間隔走より強度がやや低い高強度間隔トレーニング。より長い継続努力により、疲労下での高ペース維持に体を適応させ、乳酸耐性も向上させます。";
"training_type_info.long_interval.role" = "通常、上級スピード開発期またはハーフマラソン/10K準備期に使用。最大週1回、通常は短間隔走後に実施。十分な回復が必要です。";

"training_type_info.yasso_800.title" = "ヤッソ800";
"training_type_info.yasso_800.how_to_run" = "800mの高強度走を8-10本実施し、各本間に2-3分のジョギング回復を挟みます（800mの所要時間に相当）。例えば800mを3分で走れば、回復も約3分です。";
"training_type_info.yasso_800.why_run" = "ヤッソ800はマラソンパフォーマンスを直接予測する独特の能力を持っています。米国の有名コーチ、Bart Yasso の理論によれば、800mで出せる時間（分秒）がマラソン予想完走時間（時間分）に対応しています。";
"training_type_info.yasso_800.logic" = "800m距離はスピードと耐久力を完璧にバランスさせます。間隔設計はVO₂maxと乳酸緩衝能力を刺激。等時回復により疲労しながらペース維持能力を開発し、真のマラソン特化トレーニングです。";
