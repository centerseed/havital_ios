// MARK: - Training Type Info
"training_type_info.how_to_run_title" = "How to Run";
"training_type_info.why_run_title" = "Why Run This";
"training_type_info.logic_title" = "Training Logic";
"training_type_info.role_title" = "Role in Weekly Schedule";

// Recovery Run
"training_type_info.recovery_run.title" = "Recovery Run";
"training_type_info.recovery_run.how_to_run" = "The most relaxed running style. Slow is okay—focus on 'feeling comfortable' rather than 'good numbers.'";
"training_type_info.recovery_run.why_run" = "Recovery runs are part of active recovery. Running too fast interferes with repair, too slow is ineffective—the key is 'letting oxygen-rich blood flow through tired muscles.'";
"training_type_info.recovery_run.logic" = "Very low intensity aerobic training (<65% HRmax), helps clear lactate, promotes metabolism and nervous system recovery. Compared to static rest, prepares you faster for the next session.";
"training_type_info.recovery_run.role" = "Usually scheduled the day after high-intensity workouts or long runs, it's the key to 'absorbing' training results.";

// Tempo Run
"training_type_info.tempo.title" = "Tempo Run";
"training_type_info.tempo.how_to_run" = "Steady, somewhat challenging but sustainable pace. Should feel 'hard, but not collapsing.'";
"training_type_info.tempo.why_run" = "Tempo runs familiarize you with race pace. They train breath and pace control at medium-high intensity, bridging endurance and speed.";
"training_type_info.tempo.logic" = "Near lactate threshold (about 80–88% HRmax), improves body's lactate processing ability, enhances 'maintaining high speed without breaking down.'";
"training_type_info.tempo.role" = "Usually mid-week, simulating race pace, paired with weekend long runs and easy runs for a steady rhythm week.";

// Threshold Run
"training_type_info.threshold.title" = "Threshold Run";
"training_type_info.threshold.how_to_run" = "Slightly harder than tempo, still sustainable. Feels 'challenging but doable,' high heart rate but controlled.";
"training_type_info.threshold.why_run" = "Threshold runs are key to breaking endurance plateaus. They allow you to sustain higher speeds longer, crucial for marathon performance.";
"training_type_info.threshold.logic" = "Targets lactate threshold intensity (about 85–90% HRmax), trains body to delay lactate accumulation, improves fatigue tolerance. Long-term practice significantly boosts sustained speed and race performance.";
"training_type_info.threshold.role" = "Usually mid-week during peak training, preceded by easy runs for warm-up, followed by recovery runs to absorb stimulus.";

// Interval Run
"training_type_info.interval.title" = "Interval Run";
"training_type_info.interval.how_to_run" = "Short bursts of all-out effort alternating with recovery, will be breathless and tiring, but must 'complete all sets.'";
"training_type_info.interval.why_run" = "This is the key workout for improving speed and cardiovascular power. High-intensity stimulus teaches the body to 'run faster and recover faster.'";
"training_type_info.interval.logic" = "High-intensity interval training (HIIT), stimulates VO₂max and neuromuscular response. Improves cardiac output, oxygen delivery, and muscle oxidative capacity.";
"training_type_info.interval.role" = "Usually mid-week, the 'intensity star' of the week. Paired with easy runs or rest days for adequate recovery time.";

// LSD (Long Slow Distance)
"training_type_info.lsd.title" = "LSD (Long Slow Distance)";
"training_type_info.lsd.how_to_run" = "Slow down and extend time. Should feel like you can run forever, steady but not hard.";
"training_type_info.lsd.why_run" = "Long runs build mental and physical endurance, teaching the body to use fat as fuel for extended periods—the classic core workout for marathon training.";
"training_type_info.lsd.logic" = "Long-duration low-intensity aerobic training, strengthens cardiovascular function, muscle endurance, and energy utilization efficiency. Also promotes capillary growth, improving muscle oxygen usage.";
"training_type_info.lsd.role" = "Usually on weekends, the 'endurance pillar' of the week. Combined with mid-week tempo or interval runs to build complete aerobic capacity.";

// Long Run
"training_type_info.long_run.title" = "Long Run";
"training_type_info.long_run.how_to_run" = "Run slightly faster than easy pace, but sustainable throughout. Feels like simulating race pace, rhythmic breathing, focused forward.";
"training_type_info.long_run.why_run" = "Long runs test and build endurance. They train you to maintain steady output over extended time, and keep your body functioning under fatigue.";
"training_type_info.long_run.logic" = "Moderate-intensity long-duration aerobic training (about 70–80% HRmax). At this intensity, the body uses both fat and glycogen as fuel, improving energy utilization efficiency and muscle endurance. Also strengthens 'race pace stability' and 'mental resilience.'";
"training_type_info.long_run.role" = "Usually on weekends, the longest session of the week. During build-up or race prep, it's core training for simulating race conditions, paired with easy or recovery runs to absorb the load.";

"training_type_info.easy.title" = "Easy Run";
"training_type_info.easy.how_to_run" = "Very relaxed pace, you should be able to chat comfortably and barely breathe hard. It feels like 'running for the joy of it.'";
"training_type_info.easy.why_run" = "Easy runs form the foundation of daily training. They let your body adapt to regular running without excessive fatigue, and are key to sustaining your love for running.";
"training_type_info.easy.logic" = "Low-intensity aerobic training (about 60–70% HRmax). At this intensity, your body steadily uses fat as the primary fuel source while building aerobic capacity and capillary growth.";
"training_type_info.easy.role" = "The 'everyday hero' of training weeks. Use easy runs to warm up and recover around hard sessions, or use them solo as easy days to let your body adapt to training stress without pressure.";

"training_type_info.combination.title" = "Combination Training";
"training_type_info.combination.how_to_run" = "Combine multiple intensity zones in a single session. Start easy, then gradually speed up or alternate between sprints and recovery.";
"training_type_info.combination.why_run" = "Combination training stimulates multiple abilities in one session. It trains your body to quickly adapt to changing intensities while improving overall cardiovascular and muscular performance.";
"training_type_info.combination.logic" = "Integrates the benefits of aerobic and anaerobic training through varied intensities to stimulate multiple physiological systems. Compared to single-intensity sessions, it more comprehensively builds endurance, speed, and adaptability.";
"training_type_info.combination.role" = "Can serve as a main midweek session when time is limited but you want comprehensive training effects. Also common in race prep to simulate the varied pace of actual races.";

"training_type_info.rest.title" = "Rest Day";
"training_type_info.rest.how_to_run" = "No structured running training. You can choose gentle walking or complete static rest—listen to what your body needs.";
"training_type_info.rest.why_run" = "Rest is the most overlooked yet most critical part of training plans. Complete rest days allow muscle repair, nervous system recovery, and energy stores to replenish.";
"training_type_info.rest.logic" = "Without training load, your body undergoes deep repair. Muscle protein synthesis increases, fatigue toxins clear out, and hormonal and immune systems rebalance—this is the process of 'getting stronger through rest.'";
"training_type_info.rest.role" = "Schedule 1–2 complete rest days each week, typically after hard training. Adequate rest days prevent overtraining and maintain long-term performance and health.";

// MARK: - New Interval Training Type Info
"training_type_info.strides.title" = "Strides";
"training_type_info.strides.how_to_run" = "Short bursts (80-100 meters) of gradual acceleration. Start easy, build to near-sprint, then slow down. Stay relaxed, focus on good running form.";
"training_type_info.strides.why_run" = "Strides improve running economy and neuromuscular coordination. They help your legs get used to faster turnover and make a great warm-up before races.";
"training_type_info.strides.logic" = "A neuromuscular drill that uses short high-speed bursts to improve muscle fiber recruitment and leg coordination. The short distance and full recovery prevent significant fatigue.";
"training_type_info.strides.role" = "Usually done after easy runs or as a warm-up before hard sessions. Do them 2-3 times per week, 4-8 reps each time.";

"training_type_info.hill_repeats.title" = "Hill Repeats";
"training_type_info.hill_repeats.how_to_run" = "Find a 5-10% grade hill. Run up at a steady but challenging pace, then jog or walk down to recover. Focus on driving with your legs and leaning forward.";
"training_type_info.hill_repeats.why_run" = "Hill running is 'weight training in disguise.' It builds leg strength, improves running form, and reduces injury risk compared to flat sprinting.";
"training_type_info.hill_repeats.logic" = "Running uphill requires greater muscular output, effectively training glutes, quads, and calves. Less joint impact than flat sprints but greater muscle load.";
"training_type_info.hill_repeats.role" = "Usually scheduled in base or strength-building phases, once per week. An important transition between aerobic base and high-intensity intervals.";

"training_type_info.cruise_intervals.title" = "Cruise Intervals";
"training_type_info.cruise_intervals.how_to_run" = "Run at threshold pace (the fastest pace you can hold for 20-30 minutes) with short recovery jogs (1-2 minutes) between intervals.";
"training_type_info.cruise_intervals.why_run" = "Cruise intervals let you accumulate more volume at threshold intensity. The short recoveries allow you to spend more time at this critical intensity zone.";
"training_type_info.cruise_intervals.logic" = "A variation of threshold training that keeps your body near lactate threshold for extended periods. The interval structure allows higher total volume while maintaining good form.";
"training_type_info.cruise_intervals.role" = "Usually used in race preparation phases as an advanced version of threshold runs. Key training for improving half and full marathon performance.";

// MARK: - New Combination Training Type Info
"training_type_info.fartlek.title" = "Fartlek";
"training_type_info.fartlek.how_to_run" = "'Fartlek' is Swedish for 'speed play.' Vary your pace spontaneously during the run—sprint to the next lamppost, slow down at the park entrance. No fixed structure, just follow your feeling.";
"training_type_info.fartlek.why_run" = "Fartlek makes training fun while teaching your body to adapt to pace changes. It's a great way to break monotony and simulate race-day pace variations.";
"training_type_info.fartlek.logic" = "An unstructured mixed-intensity workout that stimulates both aerobic and anaerobic systems. The free-form approach reduces mental fatigue while delivering training benefits.";
"training_type_info.fartlek.role" = "Can replace structured interval training or serve as an easy variable-pace run during recovery weeks. Suitable for any training phase, especially when you need a mental break.";

"training_type_info.fast_finish.title" = "Fast Finish Long Run";
"training_type_info.fast_finish.how_to_run" = "Run the first 70% at easy pace, then gradually accelerate to tempo pace or faster for the final 30%. You should feel challenged but able to finish strong.";
"training_type_info.fast_finish.why_run" = "Fast finish runs train you to maintain or increase pace when tired—the exact challenge of late-race miles. They teach your body to 'push harder when fatigued.'";
"training_type_info.fast_finish.logic" = "Running at higher intensity when glycogen is depleted and muscles are tired improves fat metabolism and fatigue tolerance. Also trains form and focus maintenance.";
"training_type_info.fast_finish.role" = "Usually done during race preparation phase weekend long runs. Key training for simulating late-race conditions and building confidence.";

// MARK: - New Race Pace Training Info
"training_type_info.race_pace.title" = "Race Pace Run";
"training_type_info.race_pace.how_to_run" = "Run at your target race pace. Focus on maintaining steady rhythm, getting familiar with breathing, cadence, and body feel at this speed.";
"training_type_info.race_pace.why_run" = "Race pace runs help your body and brain memorize the target speed. On race day, you'll naturally hit this pace without constantly checking your watch.";
"training_type_info.race_pace.logic" = "By repeatedly practicing target pace, you build neuromuscular memory and pace awareness. It also helps evaluate if your current fitness can achieve your goal.";
"training_type_info.race_pace.role" = "Usually scheduled starting 4-8 weeks before race day, with distances increasing over time. One of the most important race-specific workouts.";

// MARK: - New VO2max Improvement Training Info
"training_type_info.norwegian_4x4.title" = "Norwegian 4x4";
"training_type_info.norwegian_4x4.how_to_run" = "Perform 4 intervals of 4 minutes at high intensity (92% max heart rate), with 3 minutes of easy running recovery between each. Maintain a steady VO₂max pace—you should feel \"very hard but able to complete all intervals.\"";
"training_type_info.norwegian_4x4.why_run" = "Norwegian 4x4 is the most efficient method for improving maximum oxygen uptake (VO₂max). Scientific research shows this protocol can boost aerobic capacity by approximately 7% in a short timeframe—a key workout before racing.";
"training_type_info.norwegian_4x4.logic" = "Performed at VO₂max intensity (92% max heart rate, 95-100% VO₂max), it stimulates both aerobic and anaerobic systems to their limits. The 4-minute duration is long enough to fully challenge your heart and lungs, while 3 minutes of recovery allows you to complete all intervals. This design accumulates significant training load at peak intensity.";
"training_type_info.norwegian_4x4.role" = "Typically used during build or race-prep phases, limited to once per week maximum. Pair with easy runs and ensure adequate recovery. Not suitable for consecutive weeks—needs to be balanced with recovery weeks.";

"training_type_info.short_interval.title" = "Short Interval";
"training_type_info.short_interval.how_to_run" = "Perform 6-10 repetitions of short distances (400-600 meters) at high intensity, with 1-2 minutes of easy running recovery between each. Sprint hard and let your breathing rise significantly.";
"training_type_info.short_interval.why_run" = "Short intervals train speed and explosive power. The shorter distances allow you to maintain maximum effort, while adequate recovery helps you complete all repetitions. Especially beneficial for 5K race preparation.";
"training_type_info.short_interval.logic" = "Part of high-intensity interval training (HIIT), it stimulates VO₂max and neuromuscular response. Short distances are particularly effective for developing top speed and running cadence, while also training the body's acceleration ability.";
"training_type_info.short_interval.role" = "Typically used during base speed development or 5K race-prep phases. Maximum once per week, combined with easy runs and rest days. Consecutive weeks increase injury risk.";

"training_type_info.long_interval.title" = "Long Interval";
"training_type_info.long_interval.how_to_run" = "Perform 4-6 repetitions of longer distances (1200-2000 meters) at high intensity, with 2-3 minutes of easy running recovery between each. Pace should be slightly slower than short intervals but still maintain high intensity.";
"training_type_info.long_interval.why_run" = "Long intervals bridge short intervals and continuous running. They stimulate VO₂max while maintaining high pace for longer durations, making them particularly suited for half-marathon and 10K race preparation.";
"training_type_info.long_interval.logic" = "A form of high-intensity interval training with slightly lower intensity than short intervals. The longer sustained efforts help the body adapt to maintaining high pace when fatigued, while building lactate tolerance.";
"training_type_info.long_interval.role" = "Typically used during advanced speed development or 10K/half-marathon prep phases. Maximum once per week, usually after short interval work. Requires adequate recovery.";

"training_type_info.yasso_800.title" = "Yasso 800s";
"training_type_info.yasso_800.how_to_run" = "Perform 8-10 repetitions of 800 meters at high intensity, with 2-3 minutes of easy jogging recovery between each (approximately equal to the time your 800m takes). For example, if you run 800m in 3 minutes, recover for about 3 minutes.";
"training_type_info.yasso_800.why_run" = "Yasso 800s have a unique ability to directly predict marathon performance. According to renowned coach Bart Yasso's theory, the time you run (in minutes and seconds) for 800m correlates to your predicted marathon finish time (in hours and minutes).";
"training_type_info.yasso_800.logic" = "The 800-meter distance perfectly balances speed and endurance. The interval design stimulates VO₂max and lactate buffering capacity. Equal recovery develops your ability to maintain pace while partially fatigued—true marathon-specific training.";
"training_type_info.yasso_800.role" = "Especially valuable during marathon preparation, performed once per week. The most predictive workout in marathon training. Also commonly used during other distance race preparation phases to build speed.";

