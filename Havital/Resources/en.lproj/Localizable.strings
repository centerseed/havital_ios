// Exercise Image Instructions
"exercise.instruction.title" = "Exercise Guide";

"exercise.instruction.plank.desc" = "Lie face down, lift body onto forearms & toes. Keep back straight, hips level, neck neutral. Tighten abs, glutes, & legs. Hold position.";
"exercise.instruction.squat.desc" = "Stand straight, feet apart. Lower hips, keep chest up, knees over toes. Drive through heels to return.";
"exercise.instruction.deadbug.desc" = "Lie on back with arms extended up and knees bent 90 degrees. Slowly lower one arm and the opposite leg towards the floor. Return and switch sides.";
"exercise.instruction.glute_bridge.desc" = "Lie on back, knees bent, feet flat. Squeeze glutes and lift hips until your body forms a straight line from knees to shoulders. Lower slowly.";

"exercise.instruction.bird_dog.desc" = "On all fours, keep back flat. Extend one arm forward and opposite leg back. Hold, then switch sides.";
"exercise.instruction.side_plank.desc" = "Lie on your side. Prop yourself up on one forearm and the side of your foot. Keep your body in a straight line.";
"exercise.instruction.clamshell.desc" = "Lie on your side with hips and knees bent. Keeping your feet together, raise your top knee as high as possible.";
"exercise.instruction.single_leg_glute_bridge.desc" = "Lie on your back, one knee bent, the other straight. Push through the planted foot to lift your hips.";
"exercise.instruction.monster_walk.desc" = "Keep a half-squat posture. Step laterally taking wide steps against resistance if used.";
"exercise.instruction.lunge.desc" = "Step one leg forward, bending both knees to 90 degrees. Keep back straight, then push back up.";
"exercise.instruction.romanian_deadlift.desc" = "Hinge forward at the hips while keeping your back straight and legs slightly bent. Squeeze glutes to return.";
"exercise.instruction.calf_raise.desc" = "Stand tall. Push through the balls of your feet to raise your heels as high as possible. Lower slowly.";
"exercise.instruction.vertical_jump.desc" = "Squat down briefly, then explode upwards, reaching your arms high. Land softly.";
"exercise.instruction.jump_rope.desc" = "Keep elbows close to your sides. Turn the rope and hop lightly over it on the balls of your feet.";
"exercise.instruction.lateral_jump.desc" = "Jump sideways from one foot, landing softly on the other. Repeat side to side.";
"exercise.instruction.consecutive_hops.desc" = "Hop forward or in place repeatedly, staying on the balls of your feet with a quick bounce.";
"exercise.instruction.hip_flexor_stretch.desc" = "Start in a half-kneeling position. Keep your torso upright and gently push your hips forward.";
"exercise.instruction.thoracic_rotation.desc" = "On hands and knees, place one hand behind your head. Rotate your elbow up towards the ceiling, then back down.";
"exercise.instruction.seated_forward_fold.desc" = "Sit with legs straight in front of you. Hinge at the hips and reach forward towards your toes.";
"exercise.instruction.standing_quad_stretch.desc" = "Stand on one leg, grab the other foot behind you, and gently pull your heel towards your glutes.";

